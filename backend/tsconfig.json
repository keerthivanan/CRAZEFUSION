{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "lib": ["ES2021"],
    "strict": false,
    "skipLibCheck": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "inlineSources": true,
    "noEmit": false,
    "outDir": ".medusa/server",
    "rootDir": ".",
    "paths": {}
  },
  "exclude": ["node_modules", ".medusa"]
}
